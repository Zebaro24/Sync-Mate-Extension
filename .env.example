# URL бэкенда (без trailing /). Из него выводятся:
#   API_URL = {WXT_BACKEND_URL}/api      (используется axios)
#   WS_URL  = {WXT_BACKEND_URL}/ws       (https → wss автоматически)
#
# Для разработки положи в .env.development:
#   WXT_BACKEND_URL=http://localhost:8000
# Для продакшена — в .env.production (или задай repo variable WXT_BACKEND_URL
# в GitHub → Settings → Secrets and variables → Actions → Variables — её подхватит release.yml).
WXT_BACKEND_URL=http://localhost:8000
